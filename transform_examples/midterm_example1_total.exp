(set-logic ALL)
(declare-fun lift_x$ () Int)
(declare-fun lift_g$ (Int) Int)
(declare-fun lift_f$ (Int) Int)
(assert (> (lift_f$ (lift_g$ lift_x$)) 20))
(assert (> lift_x$ 5))
(assert true)
(assert (>= lift_x$ 0))
(assert (forall ((x0 Int)) (=> (>= x0 0) (>= (lift_g$ x0) 0))))
(assert (forall ((x0 Int)) (=> (>= x0 0) (>= (lift_f$ x0) 0))))
(check-sat)
