(set-logic ALL)
(declare-fun lift_y$ () Int)
(declare-fun lift_f$ (Int Bool) Int)
(assert (forall ((lift_x$ Int) (b$ Bool)) (=> (>= lift_x$ 0) (and (>= (lift_f$ lift_x$ b$) 0) (>= (lift_f$ lift_y$ b$) 0) (= (lift_f$ lift_x$ b$) (lift_f$ lift_y$ b$))))))
(assert true)
(assert (>= lift_y$ 0))
(check-sat)
