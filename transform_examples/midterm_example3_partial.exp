(set-logic ALL)
(declare-fun lift_g$ (Int) Int)
(declare-fun lift_f$ (Int Int) Int)
(assert (forall ((lift_x$ Int)) (=> (>= lift_x$ 0) (exists ((lift_y$ Int)) (and (>= lift_y$ 0) (and (>= (lift_g$ lift_x$) 0) (>= (lift_g$ lift_y$) 0) (<= (lift_f$ (lift_g$ lift_x$) lift_y$) (lift_f$ (lift_g$ lift_y$) lift_x$))))))))
(assert true)
(check-sat)
